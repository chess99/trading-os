# Trading OS 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# API Keys (如果需要外部数据源)
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
# YAHOO_FINANCE_API_KEY=your_yahoo_finance_key
# QUANDL_API_KEY=your_quandl_key

# Claude Code 配置
CLAUDE_CODE_ENABLE_TELEMETRY=0
TRADING_OS_MODE=fund_management

# 数据库配置
# DATABASE_URL=sqlite:///data/lake.duckdb

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=artifacts/trading_os.log

# 风险管理参数
MAX_PORTFOLIO_RISK=0.15
MAX_POSITION_SIZE=0.20
MIN_CASH_BUFFER=0.05

# 回测配置
BACKTEST_INITIAL_CASH=100000
BACKTEST_COMMISSION=0.001
BACKTEST_SLIPPAGE=0.001

# 纸交易配置
PAPER_TRADING_ENABLED=true
PAPER_TRADING_INITIAL_CASH=100000

# 外部服务配置 (可选)
# REDIS_URL=redis://localhost:6379
# POSTGRES_URL=postgresql://user:password@localhost:5432/trading_os