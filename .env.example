# Trading OS 配置示例
# 复制此文件为 .env，填入实际值：cp .env.example .env
# .env 已在 .gitignore 中，不会被提交到 git

# ============================================================
# LLM 配置（Agent 策略必填，选择一个提供商）
# ============================================================

# --- 方案 A：MiniMax M2.7（OpenAI 兼容接口）---
LLM_MODEL=MiniMax-M2.7
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_API_KEY=sk-cp-your-minimax-key-here

# --- 方案 B：通义千问（Dashscope，OpenAI 兼容接口）---
# LLM_MODEL=qwen3-max-2026-01-23
# LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
# LLM_API_KEY=sk-sp-your-dashscope-key-here

# --- 方案 C：Claude（Anthropic 原生，不设 LLM_BASE_URL）---
# LLM_MODEL=claude-opus-4-6
# LLM_BASE_URL=
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ============================================================
# A 股数据源（可选，不填则只用 BaoStock 免费数据）
# ============================================================

# Tushare Pro（付费，数据最稳定，设置后自动作为 AKShare 的备选）
# TUSHARE_TOKEN=your-tushare-token-here

# ============================================================
# 日志
# ============================================================
LOG_LEVEL=INFO
